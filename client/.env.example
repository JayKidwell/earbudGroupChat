# Client Configuration

# Socket.io Server URL
# Development: http://localhost:5173 (proxied to 3001)
# Production: https://yourdomain.com
VITE_SOCKET_URL=http://localhost:5173

# WebRTC Configuration
# Production TURN server (optional but recommended for mobile)
# VITE_TURN_URL=turn:yourdomain.com:3478
# VITE_TURN_USERNAME=username
# VITE_TURN_PASSWORD=password
